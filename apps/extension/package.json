{
  "name": "crispy",
  "version": "1.0.0",
  "description": "The VScode extension for crispy",
  "displayName": "CrisPy",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1A202C",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "education",
    "extension",
    "python"
  ],
  "homepage": "https://github.com/snail-unamur/CrisPy#readme",
  "bugs": {
    "url": "https://github.com/snail-unamur/CrisPy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snail-unamur/CrisPy.git"
  },
  "license": "MIT",
  "author": "Snail-Unamur",
  "publisher": "snail-unamur",
  "main": "./out/extension.js",
  "types": "./out/extension.d.ts",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:python",
    "onDocuments:python"
  ],
  "contributes": {
    "languages": [
      {
        "id": "crispy",
        "aliases": [
          "CrisPy"
        ],
        "extensions": [
          ".crispy"
        ],
        "configuration": "./language/language-configuration.json",
        "mimetypes": [
          "application/json"
        ],
        "icon": {
          "light": "./media/icon-light.png",
          "dark": "./media/icon.png"
        }
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.crispy",
        "url": "./language/crispy.schema.json"
      }
    ],
    "grammars": [
      {
        "language": "crispy",
        "scopeName": "source.crispy",
        "path": "./language/crispy.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "json"
        }
      }
    ]
  },
  "installationInfo": {
    "identifier": "snail-unamur.crispy",
    "version": "1.0.1",
    "source": "Local",
    "cacheSize": "2B",
    "categories": [
      "Other",
      "SCM Providers"
    ]
  },
  "files": [
    "out/**",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "clean": "rm -rf out"
  },
  "dependencies": {
    "@crispy/rules": "workspace:*",
    "marked": "^17.0.4",
    "rehype-pretty-code": "^0.14.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
