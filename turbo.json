{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate-schema": {
      "dependsOn": ["^build"],
      "outputs": ["../apps/extension/language/crispy.schema.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"]
    },
    "dev": {
      "cache": false
    },
    "clean": {}
  }
}
